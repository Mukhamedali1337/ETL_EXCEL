<%- include("partials/header", { title: "Загрузка Excel", heading: "Загрузка Excel" }) %>

<section class="hero-grid">
  <div class="card">
    <h2>Выбор типа импорта</h2>
    <p class="muted">
      Подготовили 6 типов загрузки. Сейчас полностью настроен первый шаблон, остальные доступны как каркас для дальнейшего заполнения столбцов и правил.
    </p>
    <div class="template-selector">
      <% templates.forEach((template) => { %>
        <a
          href="/upload?template=<%= template.id %>"
          class="template-pill <%= selectedTemplate && selectedTemplate.id === template.id ? "template-pill-active" : "" %>"
        >
          <span><%= template.name %></span>
          <small><%= template.ready ? "Готов" : "В ожидании" %></small>
        </a>
      <% }) %>
    </div>
  </div>

  <div class="card accent-card">
    <h2><%= selectedTemplate ? selectedTemplate.name : "Тип импорта" %></h2>
    <p class="muted"><%= selectedTemplate ? selectedTemplate.description : "" %></p>

    <h3>Ожидаемые колонки</h3>
    <div class="template-grid">
      <% if (selectedTemplate && selectedTemplate.requiredHeaders && selectedTemplate.requiredHeaders.length > 0) { %>
        <% selectedTemplate.requiredHeaders.forEach((header) => { %>
          <span><%= header %></span>
        <% }) %>
      <% } else { %>
        <span>Столбцы будут добавлены позже</span>
      <% } %>
    </div>

    <h3>Правила</h3>
    <ul class="check-list">
      <% if (selectedTemplate && selectedTemplate.rules && selectedTemplate.rules.length > 0) { %>
        <% selectedTemplate.rules.forEach((rule) => { %>
          <li><%= rule %></li>
        <% }) %>
      <% } else { %>
        <li>Правила еще не заданы</li>
      <% } %>
    </ul>
  </div>
</section>

<section class="card">
  <h2>Загрузить файл</h2>
  <% if (error) { %>
    <div class="alert alert-error"><%= error %></div>
  <% } %>
  <% if (success) { %>
    <div class="alert alert-success"><%= success %></div>
  <% } %>

  <% if (selectedTemplate && !selectedTemplate.ready) { %>
    <div class="alert">
      Для <strong><%= selectedTemplate.name %></strong> загрузка временно выключена: дождемся список столбцов и условий.
    </div>
  <% } %>

  <form method="post" action="/upload" enctype="multipart/form-data" class="form-stack">
    <input type="hidden" name="templateType" value="<%= selectedTemplate ? selectedTemplate.id : "" %>" />
    <label>
      Excel-файл
      <input
        type="file"
        name="excelFile"
        accept=".xlsx,.xls"
        <%= selectedTemplate && !selectedTemplate.ready ? "disabled" : "required" %>
      />
    </label>
    <button class="primary-button" type="submit" <%= selectedTemplate && !selectedTemplate.ready ? "disabled" : "" %>>
      Проверить файл
    </button>
  </form>
</section>

<% if (preview) { %>
  <section class="preview-grid">
    <div class="card">
      <h2>Предпросмотр импорта</h2>
      <div class="stats-grid">
        <div class="stat-box">
          <strong><%= preview.originalFileName %></strong>
          <span>Файл</span>
        </div>
        <div class="stat-box">
          <strong><%= preview.templateName || "Не указан" %></strong>
          <span>Тип импорта</span>
        </div>
        <div class="stat-box">
          <strong><%= preview.totalRows %></strong>
          <span>Всего строк</span>
        </div>
        <div class="stat-box">
          <strong><%= preview.validRows.length %></strong>
          <span>Валидных строк</span>
        </div>
        <div class="stat-box">
          <strong><%= preview.errors.length %></strong>
          <span>Ошибок</span>
        </div>
      </div>

      <form method="post" action="/import">
        <button class="primary-button" type="submit" <%= preview.validRows.length === 0 ? "disabled" : "" %>>
          Подтвердить импорт
        </button>
      </form>
    </div>

    <div class="card">
      <h2>Валидные строки</h2>
      <% if (preview.validRows.length === 0) { %>
        <p class="muted">Нет строк, готовых к импорту.</p>
      <% } else { %>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>employee_id</th>
                <th>full_name</th>
                <th>email</th>
                <th>course_code</th>
                <th>course_name</th>
                <th>completion_date</th>
                <th>score</th>
              </tr>
            </thead>
            <tbody>
              <% preview.validRows.slice(0, 20).forEach((row) => { %>
                <tr>
                  <td><%= row.employee_id %></td>
                  <td><%= row.full_name %></td>
                  <td><%= row.email %></td>
                  <td><%= row.course_code %></td>
                  <td><%= row.course_name %></td>
                  <td><%= row.completion_date %></td>
                  <td><%= row.score %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </section>

  <section class="card">
    <h2>Ошибки проверки</h2>
    <% if (preview.errors.length === 0) { %>
      <div class="alert alert-success">Ошибок не найдено.</div>
    <% } else { %>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Строка</th>
              <th>Поле</th>
              <th>Ошибка</th>
            </tr>
          </thead>
          <tbody>
            <% preview.errors.forEach((errorItem) => { %>
              <tr>
                <td><%= errorItem.rowNumber %></td>
                <td><%= errorItem.field %></td>
                <td><%= errorItem.message %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </section>
<% } %>

<%- include("partials/footer") %>
