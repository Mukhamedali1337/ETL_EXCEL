<%- include("../partials/header", { title: "Админ — Таблицы", heading: "Таблицы базы данных" }) %>

<div style="display:flex; gap:12px; margin-bottom:24px; flex-wrap:wrap;">
  <a class="nav-link" href="/admin">Дашборд</a>
  <a class="nav-link" href="/admin/users">Пользователи</a>
  <a class="nav-link" href="/admin/tables">Таблицы</a>
  <a class="nav-link" href="/admin/templates">Шаблоны</a>
</div>

<% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>
<% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>

<section class="card">
  <h2>Пользовательские таблицы (<%= tables.length %>)</h2>
  <p class="muted" style="margin-bottom:16px;">Таблицы, созданные через «Свободную загрузку». Системные таблицы не показаны.</p>
  <% if (!tables.length) { %>
    <p class="muted">Таблиц пока нет.</p>
  <% } else { %>
    <div class="table-wrap">
      <table>
        <thead>
          <tr><th>Имя таблицы</th><th>Строк</th><th>Создана</th><th></th></tr>
        </thead>
        <tbody>
          <% tables.forEach(t => { %>
            <tr>
              <td><strong><%= t.name %></strong></td>
              <td><%= t.row_count.toLocaleString("ru-RU") %></td>
              <td class="muted"><%= new Date(t.create_date).toLocaleDateString("ru-RU") %></td>
              <td style="display:flex; gap:8px;">
                <a href="/admin/tables/<%= encodeURIComponent(t.name) %>" class="nav-link" style="padding:6px 12px; font-size:0.9em;">Просмотр</a>
                <form method="post" action="/admin/tables/<%= encodeURIComponent(t.name) %>/delete" style="display:inline;">
                  <button type="submit"
                    style="padding:6px 12px; border-radius:999px; border:1px solid rgba(184,75,58,0.4); background:rgba(184,75,58,0.08); color:#b84b3a; cursor:pointer; font:inherit; font-size:0.9em;"
                    onclick="return confirm('Удалить таблицу «<%= t.name %>»? Данные будут потеряны безвозвратно.')">
                    Удалить
                  </button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</section>

<%- include("../partials/footer") %>
